pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Build') {
            steps {
               dir('AuthService') {
                sh "docker build -t auth-service:latest ."
            }
        }

    }

    post {
        success {
            echo "✅ Auth service CI passed"
        }
        failure {
            echo "❌ Auth service CI is fail"
        }
        always {
            sh "docker rmi auth-service:latest || true"
            cleanWs()
        }
    }
}